# ═══════════════════════════════════════════════════════════════════════════════
# AgriSmart Kenya — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local for development
# NEVER commit real credentials to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ── Firebase Configuration ────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# ── External API URLs ─────────────────────────────────────────────────────────
VITE_WEATHER_PROXY_URL=
VITE_ALERTS_WORKER_URL=
VITE_ADVISORY_API_BASE_URL=
VITE_ADVISORY_WORKER_URL=
VITE_ADVISORY_API_URL=
VITE_RENDER_API_URL=
VITE_MARKET_API_URL=
VITE_COMMUNITY_API_BASE_URL=
VITE_ASHA_API_BASE_URL=
VITE_BUYER_API_BASE_URL=

# ── Feature Flags ─────────────────────────────────────────────────────────────
VITE_USE_MOCK_ADVISORY=false
VITE_ENABLE_COOP_TRADE=true
VITE_INTL_SIM_ENABLED=true
VITE_ENABLE_BUYER_TRADE=true
VITE_ENABLE_BUYER_DASHBOARD=true
VITE_ENABLE_BUYER_BILLING=true
VITE_ENABLE_TEST_DEPOSIT=false
VITE_ENABLE_KENYA_MEMBER_MAP=false
VITE_ENABLE_KENYA_MEMBER_MAP_ADVANCED=false
VITE_ENABLE_KENYA_MEMBER_MAP_MARKET_OPPORTUNITY=false
VITE_ENABLE_KENYA_MEMBER_MAP_COLLECTION_PLANNING=false
VITE_ENABLE_KENYA_MEMBER_MAP_RISK=false
VITE_ENABLE_COMMUNITY_FARMD=false

# ── Payment ───────────────────────────────────────────────────────────────────
VITE_MPESA_FUNCTION_NAME=initiateMpesaPayment
VITE_MPESA_MOCK_MODE=true

# ── Public ────────────────────────────────────────────────────────────────────
VITE_PUBLIC_SITE_URL=http://localhost:5173
