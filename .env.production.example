# ═══════════════════════════════════════════════════════════════════════════════
# AgriSmart Kenya — PRODUCTION Environment
# ═══════════════════════════════════════════════════════════════════════════════
# WARNING: This file should NEVER contain real credentials.
# Use CI/CD secrets or a secrets manager for production values.
# ═══════════════════════════════════════════════════════════════════════════════

# All VITE_ variables are embedded in the frontend bundle at build time.
# Only include values that are safe to be public (project IDs, public URLs).
# Private keys, secrets, and credentials must NEVER be in VITE_ variables.

VITE_FIREBASE_API_KEY=${FIREBASE_API_KEY}
VITE_FIREBASE_AUTH_DOMAIN=agrismartkenya.com
VITE_FIREBASE_PROJECT_ID=crop-conduit-ui
VITE_FIREBASE_STORAGE_BUCKET=crop-conduit-ui.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=${FIREBASE_MESSAGING_SENDER_ID}
VITE_FIREBASE_APP_ID=${FIREBASE_APP_ID}
VITE_FIREBASE_MEASUREMENT_ID=${FIREBASE_MEASUREMENT_ID}
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

VITE_ENABLE_TEST_DEPOSIT=false
VITE_MPESA_MOCK_MODE=false
VITE_PUBLIC_SITE_URL=https://agrismartkenya.com
